generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleRu     String
  titleEn     String
  taglineRu   String
  taglineEn   String
  problemRu   String
  problemEn   String
  beforeRu    String
  beforeEn    String
  solutionRu  String
  solutionEn  String
  valueRu     String
  valueEn     String
  techStack   String   // JSON array string
  screenshots String   // JSON array of file paths
  videoUrl    String?
  liveUrl     String?
  githubUrl   String?
  order       Int      @default(0)
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}
